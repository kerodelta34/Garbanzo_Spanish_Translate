CUTSCENE_FRIENDS = AMIGOS

# HELP

OFFER_HELP_1 = Hola, no quiero molestarte, pero parece que tienes un pequeño problema. ¡No pasa nada!
OFFER_HELP_2 = Quizás te interese echar un vistazo al Menú de Modificadores, donde podrás modificar las reglas. ¿Te gustaría hacerlo ahora?

OFFER_HELP_3 = ¡Velep! Puedes cambiar un poco las reglas en el Menú de Modificadores en Opciones.
OFFER_HELP_4 = ¡Ahora sal ahí fuera!

OFFER_HELP_5 = Entendido. No te molestaré más.
OFFER_HELP_6 = Recuerda, puedes activar el menú de Modificadores en cualquier moemnto en la Pantalla de Inicio.
OFFER_HELP_7 = ¡Sé que puedes hacerlo!

TWEAKS_MESSAGE = Esto quiere ser una experiencia desafiante, aunque gratificante. Fue diseñado con reglas específicas en mente, pero si eso resulta ser frustrante para ti, puedes Modificar esas reglas tanto como quieras.\n\n<color=#ff0000>También puedes hacer el juego más difícil si eso te interesa :)</color>

# TIPS

TIP_GRAVITY_UP = ¡Mantén Saltar\n para subir! 
TIP_GRAVITY_DOWN = ¡Mantén Saltar para\n ralentizar la caída! 
TIP_SPIT_BULLETS = Escupe en las balas\n, ¿quieres?
TIP_SPIT_FASTER = ¡Mantén Escupitajo\n para subir! 
