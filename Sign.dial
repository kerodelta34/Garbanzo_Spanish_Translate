SIGN.FREEDOMLAND =
    PROPIEDAD DE {ABRA_CADABRA}. MANTENTE ALEJADO O PODRÍAS <s=10>MORIR.</s>

    SI MUERES, ES TOTALMENTE UN ACCIDENTE Y {ABRA_CADABRA} <s=5>NO</s> SE HARÁ RESPONSABLE.

    TODA MÁQUINA MORTAL ENCONTRADA EN LAS INSTALACIONES ES UNA MERA COINCIDENCIA.

SIGN.HAHA_1 =
    ¡Jaja, bien jugado! ¿Cómo has llegado aquí, pequeño granuja?

SIGN.HAHA_2 =
    <s=10>¡Granuja!<s>

SIGN.STOP_1 =
    <f=2,10>¡WOW! ¡AL FINAL ME ENCONTRASTÉ!</f>

    <f=2,10>¡SOY EL CARTEL MÁS ESPECIAL DEL JUEGO!</f>

    @S1

    SOY EL CARTEL QUE <s=10>BORRA</s> TU PARTIDA SI ME ENCUENTRAS.

    @S2

    <f=2,10>¡ES BROMA!</f>

    <f=2,10>PERO HABRÍA SIDO MUY DIVERTIDO.</f>

SIGN.STOP_2 =
    <f=2,10>¡¿POR QUÉ ME HABLARÍAS OTRA VEZ?!</f>

    @S1

    <c=#ff0000>¡HABLAME OTRA VEZ Y PUEDE QUE AHORA LO HAGA!</c>

SIGN.STOP_3 =
    [AutoProceed: true]
    <c=#ff0000>¡PERFECTO! ¡TÚ LO PEDISTE!</c>

    @S3

